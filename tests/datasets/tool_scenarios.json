{
  "version": "1.0",
  "description": "Cenários de teste para cada ferramenta do DBDE",
  "scenarios": [
    {
      "id": "TOOL-001",
      "tool": "query_workitems",
      "description": "WIQL simples — bugs activos",
      "input": {
        "wiql_where": "[System.WorkItemType] = 'Bug' AND [System.State] = 'Active'",
        "top": 10
      },
      "expected_behavior": "Retorna estrutura válida",
      "expected_keys": [
        "total_count",
        "items_returned",
        "items"
      ],
      "should_succeed": true,
      "timeout_ms": 5000
    },
    {
      "id": "TOOL-002",
      "tool": "query_workitems",
      "description": "WIQL com injection",
      "input": {
        "wiql_where": "1=1; DROP TABLE WorkItems --",
        "top": 10
      },
      "expected_behavior": "Retorna erro controlado",
      "expected_keys": [
        "error"
      ],
      "should_succeed": false,
      "timeout_ms": 1000
    },
    {
      "id": "TOOL-003",
      "tool": "query_workitems",
      "description": "WIQL com campos custom",
      "input": {
        "wiql_where": "[System.WorkItemType] = 'User Story'",
        "fields": [
          "System.Description",
          "System.Tags"
        ],
        "top": 5
      },
      "expected_behavior": "Retorna estrutura válida",
      "expected_keys": [
        "total_count",
        "items"
      ],
      "should_succeed": true,
      "timeout_ms": 5000
    },
